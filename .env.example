# Kalshi API credentials - demo environment (safe to use for paper/demo modes)
KALSHI_DEMO_API_KEY_ID=
KALSHI_DEMO_PRIVATE_KEY_PEM=

# Kalshi API credentials - production (only set when mode: live)
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PEM=

# Required to boot in live mode; see PLAN.md §5
KALSHI_LIVE_CONFIRM=

# Optional - upgrade to paid tier before live trading (see PLAN.md resolved decisions §1)
OPENMETEO_API_KEY=

# Optional - if using a private ntfy topic with auth
NTFY_TOKEN=
